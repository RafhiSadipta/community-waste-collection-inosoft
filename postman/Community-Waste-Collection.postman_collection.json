    {
      "name": "Waste Pickup",
      "item": [
        {
          "name": "Get Existing Household (for Waste testing)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const items = json.data.items;",
                  "pm.test('At least 1 household exists (run Household seeder if this fails)', () => pm.expect(items.length).to.be.above(0));",
                  "if (items.length > 0) {",
                  "    pm.collectionVariables.set('waste_test_household_id', items[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/households?per_page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "households"],
              "query": [{ "key": "per_page", "value": "1" }]
            }
          }
        },
        {
          "name": "Create Pickup - Organic",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('pickup_organic_id', json.data.id);",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('type is organic', () => pm.expect(pm.response.json().data.type).to.eql('organic'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"household_id\": \"{{waste_test_household_id}}\",\n  \"type\": \"organic\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/pickups",
              "host": ["{{base_url}}"],
              "path": ["api", "pickups"]
            }
          }
        },
        {
          "name": "Create Pickup - Electronic",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('pickup_electronic_id', json.data.id);",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('safety_check defaults false', () => pm.expect(pm.response.json().data.safety_check).to.eql(false));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"household_id\": \"{{waste_test_household_id}}\",\n  \"type\": \"electronic\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/pickups",
              "host": ["{{base_url}}"],
              "path": ["api", "pickups"]
            }
          }
        },
        {
          "name": "Create Pickup - Plastic (representative for Plastic/Paper)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
