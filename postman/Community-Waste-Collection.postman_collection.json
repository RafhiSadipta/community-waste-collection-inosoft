{
  "info": {
    "_postman_id": "b6f2a5d4-3c8e-4e2a-9f1a-waste-collection-api",
    "name": "Community Waste Collection API",
    "description": "Take Home Test - PT Inosoft Trans Sistem. Base URL default: http://localhost:8000 (Laravel via Docker).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Household",
      "item": [
        {
          "name": "Create Household",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('household_id', json.data.id);",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has success=true', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"owner_name\": \"Budi Santoso\",\n  \"address\": \"Jl. Mawar No. 12\",\n  \"block\": \"A\",\n  \"no\": \"12\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/households",
              "host": ["{{base_url}}"],
              "path": ["api", "households"]
            }
          }
        },
        {
          "name": "Create Household - Validation Error",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 422', () => pm.response.to.have.status(422));",
                  "pm.test('Has field errors', () => pm.expect(pm.response.json().errors).to.have.property('owner_name'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"Jl. Tanpa Nama\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/households",
              "host": ["{{base_url}}"],
              "path": ["api", "households"]
            }
          }
        },
        {
          "name": "List Households",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/households?search=&block=&no=&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "households"],
              "query": [
                { "key": "search", "value": "" },
                { "key": "block", "value": "" },
                { "key": "no", "value": "" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        },
        {
          "name": "Get Household by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/households/{{household_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "households", "{{household_id}}"]
            }
          }
        },
        {
          "name": "Update Household",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"Jl. Mawar No. 12B\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/households/{{household_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "households", "{{household_id}}"]
            }
          }
        },
        {
          "name": "Get Household - Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/households/000000000000000000000000",
              "host": ["{{base_url}}"],
              "path": ["api", "households", "000000000000000000000000"]
            }
          }
        },
        {
          "name": "Delete Household",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/households/{{household_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "households", "{{household_id}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "household_id", "value": "" }
  ]
